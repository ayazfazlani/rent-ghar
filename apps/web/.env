# API URL Configuration
# Browser-facing API URL (used by client-side axios calls from the browser)
NEXT_PUBLIC_API_URL=https://propertydealer.pk

# Internal API URL for server-side (SSR) Next.js fetches.
# Use localhost so SSR calls go directly to the API process without
# routing through nginx/public domain (avoids loopback network issues on live).
INTERNAL_API_URL=http://localhost:3005

APP_URL=http://localhost:3000

PORT=3010

# For development (local):
# NEXT_PUBLIC_API_URL=http://localhost:3005
# INTERNAL_API_URL=http://localhost:3005